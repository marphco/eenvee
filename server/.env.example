# ============================================================================
# eenvee — server environment variables (template)
# ----------------------------------------------------------------------------
# Copia questo file in `server/.env` e compila i valori.
# Non committare mai il vero .env (è ignorato da .gitignore).
# ============================================================================

# ---- Core ------------------------------------------------------------------
# Ambiente di esecuzione: `development` (default) | `production`
NODE_ENV=development

# Porta HTTP del server Express (default 4000)
PORT=4000

# Origini CORS ammesse, separate da virgola (niente spazi).
# In dev basta il dev server Vite; in prod va messo il dominio pubblico.
CLIENT_ORIGINS=http://localhost:5173,http://localhost:5174

# ---- Database --------------------------------------------------------------
# Connection string MongoDB (Atlas o locale)
MONGO_URI=mongodb://localhost:27017/eenvee

# ---- Auth ------------------------------------------------------------------
# Secret per firmare i JWT (usa almeno 32 caratteri random)
JWT_SECRET=change-me-to-a-long-random-string

# ---- Email (SMTP, es. Gmail app password) ----------------------------------
# Lasciare vuoti disattiva l'invio email (il server logga soltanto).
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=hello@eenvee.com

# Notifiche interne acquisto Premium (webhook). Default: info@eenvee.com
INTERNAL_NOTIFY_EMAIL=info@eenvee.com

# ---- Cloudflare R2 (storage immagini/video) --------------------------------
# Lasciare vuoti abilita il fallback su `server/uploads` in locale.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ---- Stripe (Busta Digitale — Connect Express) -----------------------------
# Creare un account Stripe, abilitare Connect → copiare le chiavi dal dashboard
# Dashboard → Developers → API keys (modalità Test).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret. In locale si ottiene lanciando:
#   stripe listen --forward-to http://localhost:4000/api/stripe/webhooks
# In produzione si copia dal pannello Webhooks del dashboard Stripe.
STRIPE_WEBHOOK_SECRET=whsec_...

# Commissione piattaforma applicata a ogni donazione (default 3% + 0,50 €).
# Modificare solo se cambia la strategia di pricing.
STRIPE_PLATFORM_FEE_PERCENT=3
STRIPE_PLATFORM_FEE_FIXED_CENTS=50

# Sblocco evento Premium (€49): usa Stripe Checkout automatico quando STRIPE_SECRET_KEY
# è una chiave reale (sk_test… / sk_live…). Chiave assente o contenente "mock" → solo
# percorso mock in sviluppo (nessun addebito).
