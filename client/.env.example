# ============================================================================
# eenvee — client environment variables (template)
# ----------------------------------------------------------------------------
# Copia questo file in `client/.env` e compila i valori.
# Tutte le variabili esposte al client DEVONO iniziare con `VITE_` (Vite).
# Non mettere MAI qui secret/chiavi private: il bundle è pubblico.
# ============================================================================

# URL base delle API server-side. Default: `/api` (reverse proxy Vite in dev).
# Imposta solo se il client gira su un dominio diverso dal server.
VITE_API_URL=

# Stripe publishable key (pk_test_... in sviluppo, pk_live_... in produzione).
# È pensata per essere pubblica — NON è un secret.
# Serve a montare Payment Element e Connect Embedded Components nel client.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
